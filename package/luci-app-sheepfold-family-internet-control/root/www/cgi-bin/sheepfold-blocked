#!/bin/sh

DEFAULT_TEXT="Internet is temporarily unavailable by family rules."
MESSAGE="$(uci -q get sheepfold.global.blocked_page_text 2>/dev/null || printf '%s' "$DEFAULT_TEXT")"
METHOD="${REQUEST_METHOD:-GET}"
ACCEPT="${HTTP_ACCEPT:-}"

json_escape() {
        printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

html_escape() {
        printf '%s' "$1" | sed 's/&/\&amp;/g; s/</\&lt;/g; s/>/\&gt;/g; s/"/\&quot;/g'
}

common_headers() {
        printf 'Status: 403 Forbidden\r\n'
        printf 'Cache-Control: no-store, no-cache, must-revalidate, max-age=0\r\n'
        printf 'Pragma: no-cache\r\n'
        printf 'X-Sheepfold-Blocked: 1\r\n'
}

case "$ACCEPT:$METHOD" in
        *application/json*|*:POST|*:PUT|*:PATCH|*:DELETE)
                common_headers
                printf 'Content-Type: application/json; charset=utf-8\r\n\r\n'
                printf '{"blocked":true,"reason":"family_rules","message":"%s"}\n' "$(json_escape "$MESSAGE")"
                ;;
        *text/plain*)
                common_headers
                printf 'Content-Type: text/plain; charset=utf-8\r\n\r\n'
                printf '%s\n' "$MESSAGE"
                ;;
        *)
                common_headers
                printf 'Content-Type: text/html; charset=utf-8\r\n\r\n'
                cat <<EOF
<!doctype html>
<html lang="ru">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Sheepfold</title>
<style>
body{margin:0;font-family:system-ui,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:#bdd7ce;color:#14221d;display:grid;min-height:100vh;place-items:center}
main{width:min(560px,calc(100vw - 32px));background:#fff;border:1px solid rgba(20,34,29,.18);border-radius:8px;padding:24px;box-shadow:0 16px 40px rgba(20,34,29,.16)}
h1{font-size:24px;margin:0 0 12px}
p{font-size:17px;line-height:1.45;margin:0}
</style>
</head>
<body>
<main>
<h1>Sheepfold</h1>
<p>$(html_escape "$MESSAGE")</p>
</main>
</body>
</html>
EOF
                ;;
esac
